rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 1. BOOK COVERS FOLDER
    match /book_covers/{fileName} {
      // Anyone can see the book covers (public)
      allow read: if true; 
      // Only logged-in admins should be able to upload covers
      allow write: if request.auth != null; 
    }

    // 2. RECEIPTS FOLDER
    match /receipts/{fileName} {
      // Only logged-in users and admins can see receipts
      allow read: if request.auth != null;
      
      // Only logged-in users can upload, must be an image, under 5MB
      allow write: if request.auth != null 
                   && request.resource.contentType.matches('image/.*')
                   && request.resource.size < 5 * 1024 * 1024;
    }

  
    //other buckets are closed (potentialy upload to unknown bucket)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}