DATABASE_URL=postgresql://user:pass@localhost:5432/ebook_platform
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
PORT=3000

# S3 / Cloudflare R2 (book content storage)
S3_ACCESS_KEY=your-r2-access-key-id
S3_SECRET_KEY=your-r2-secret-access-key
S3_REGION=auto
S3_BUCKET=your-bucket-name
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev
S3_FORCE_PATH_STYLE=false

# Redis (BullMQ queue for flipbook post-processing)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
